{
  "expo": {
    "name": "PrestoID",
    "slug": "prestoid",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "prestoid",
    "icon": "./assets/images/icon.png",
    "notification": {
      "icon": "./assets/images/notification_icon.png",
      "color": "#AF2800"
    },
    "splash": {
      "backgroundColor": "#FFF8F6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kanelijo.prestoid",
      "infoPlist": {
        "NSCameraUsageDescription": "PrestoID needs camera access to scan student QR codes for attendance.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "launchMode": "singleTask",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFF8F6"
      },
      "package": "com.kanelijo.prestoid",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "PrestoID needs camera access to scan student QR codes."
        }
      ],
      "expo-font",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-sharing",
      "@react-native-google-signin/google-signin",
      "expo-image",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21c7809d-2515-4745-b2d6-ea7e6337e0ad"
      }
    },
    "owner": "andrewnks-team"
  }
}
